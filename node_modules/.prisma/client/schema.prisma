generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  WRITER
  ADMIN
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  password        String
  name            String
  role            Role             @default(STUDENT)
  submissions     Submission[]
  contestsCreated Contest[]        @relation("ContestCreator")
  sessions        ContestSession[] // 👈 Added relation
  createdAt       DateTime         @default(now())
}

model Contest {
  id           String           @id @default(uuid())
  title        String           @default("Untitled Contest")
  description  String?          @db.Text
  startTime    DateTime?
  endTime      DateTime?
  isPrivate    Boolean          @default(false)
  joinCode     String?          @unique
  strikes      Int              @default(3)
  strictMode   Boolean          @default(true)
  allowedLangs String           @default("Python,Python 3,Java,C,C++,C#")
  status       String           @default("DRAFT")
  creatorId    String
  creator      User             @relation("ContestCreator", fields: [creatorId], references: [id])
  problems     Problem[]
  sessions     ContestSession[] // 👈 Added relation
  createdAt    DateTime         @default(now())
}

// 👇 NEW MODEL: Tracks active exam takers, strikes, and status
model ContestSession {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  contestId   String
  contest     Contest   @relation(fields: [contestId], references: [id])
  strikes     Int       @default(0)
  status      String    @default("IN_PROGRESS") // "IN_PROGRESS", "SUBMITTED", "KICKED"
  joinedAt    DateTime  @default(now())
  completedAt DateTime?

  @@unique([userId, contestId]) // A user can only have one active session per contest
}

model Problem {
  id          String       @id @default(uuid())
  title       String
  description String       @db.Text
  diff        String
  tag         String?
  codeStubs   Json?
  solution    Json?
  testCases   TestCase[]
  contests    Contest[]
  submissions Submission[]
  createdAt   DateTime     @default(now())
}

model TestCase {
  id             String  @id @default(uuid())
  input          String  @db.Text
  expectedOutput String  @db.Text
  isHidden       Boolean @default(false)
  problemId      String
  problem        Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

model Submission {
  id          String   @id @default(uuid())
  code        String   @db.Text
  language    String
  status      String
  runtime     Int?
  memory      Int?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  problemId   String
  problem     Problem  @relation(fields: [problemId], references: [id])
  submittedAt DateTime @default(now())
}
